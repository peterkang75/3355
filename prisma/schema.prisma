generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id               String    @id @default(cuid())
  name             String
  phone            String    @unique
  nickname         String?
  gender           String?
  birthYear        String?
  region           String?
  isClubMember     String?
  club             String?
  handicap         String?
  gaHandy          String?
  houseHandy       String?
  golflinkNumber   String?
  clubMemberNumber String?
  isAdmin          Boolean   @default(false)
  role             String    @default("회원")
  balance          Int       @default(0)
  photo            String?
  isActive         Boolean   @default(true)
  approvalStatus   String    @default("approved")
  canManageFees    Boolean   @default(false)
  isFeeExempt      Boolean   @default(false)
  lastActiveAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  posts                 Post[]
  bookings              Booking[]
  playerScores          Score[]       @relation("PlayerScores")
  markerScores          Score[]       @relation("MarkerScores")
  fees                  Fee[]         @relation("MemberFees")
  transactions          Transaction[] @relation("MemberTransactions")
  executedTransactions  Transaction[] @relation("ExecutorTransactions")
  activityLogs          ActivityLog[]
  voterPredictions      WinnerPrediction[] @relation("VoterPredictions")
  predictedWinnerOf     WinnerPrediction[] @relation("PredictedWinner")
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  author    Member   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  Json     @default("[]")
  likes     Json     @default("[]")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
}

model Booking {
  id                   String   @id @default(cuid())
  title                String?
  type                 String   @default("정기모임")
  courseName           String
  date                 String
  time                 String
  gatheringTime        String?
  organizerId          String
  organizer            Member   @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  participants         String[]
  numberRentals        String[] @default([])
  status               String   @default("pending")
  notes                String?
  greenFee             Int?
  cartFee              Int?
  membershipFee        Int?
  registrationDeadline String?
  restaurantName       String?
  restaurantAddress    String?
  isAnnounced          Boolean  @default(false)
  playEnabled          Boolean  @default(false)
  playManuallyDisabled Boolean  @default(false)
  isGuestAllowed       Boolean  @default(false)
  useSquadWaitlist     Boolean  @default(false)
  votingEnabled        Boolean  @default(true)
  is2BB                Boolean  @default(false)
  isSocial             Boolean  @default(false)
  maxMembers           Int      @default(4)
  teams                Json?
  gradeSettings        Json?
  dailyHandicaps       Json?
  twoBallTeams         Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  transactions      Transaction[]
  winnerPredictions WinnerPrediction[]

  @@index([organizerId])
  @@index([date])
}

model Fee {
  id          String   @id @default(cuid())
  title       String
  amount      Int
  type        String
  date        String
  dueDate     String?
  appliesTo   String
  status      String   @default("pending")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members Member[] @relation("MemberFees")

  @@index([date])
  @@index([status])
}

model Transaction {
  id            String   @id @default(cuid())
  type          String
  category      String?
  amount        Float
  memberId      String?
  member        Member?  @relation(fields: [memberId], references: [id], onDelete: Cascade, name: "MemberTransactions")
  bookingId     String?
  booking       Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  description   String?
  memo          String?
  receiptImage  String?
  receiptImages Json?
  date          String
  createdBy     String?
  executor      Member?  @relation(fields: [createdBy], references: [id], onDelete: SetNull, name: "ExecutorTransactions")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([memberId])
  @@index([bookingId])
  @@index([createdBy])
  @@index([type])
  @@index([date])
}

model Score {
  id           String   @id @default(cuid())
  userId       String
  user         Member   @relation(fields: [userId], references: [id], onDelete: Cascade, name: "PlayerScores")
  markerId     String?
  marker       Member?  @relation(fields: [markerId], references: [id], onDelete: SetNull, name: "MarkerScores")
  roundingName String?
  date         String
  courseName   String
  totalScore   Int
  coursePar    Int      @default(72)
  holes        String?
  completed    Boolean  @default(false)
  verified     Boolean  @default(false)
  verifiedBy   String?
  gameMode     String?
  gameMetadata String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, date, roundingName])
  @@index([userId])
  @@index([markerId])
  @@index([date])
  @@index([roundingName])
}

model Course {
  id            String  @id @default(cuid())
  name          String  @unique
  address       String
  holePars      Json?
  nearHoles     Json?   @default("[]")
  isCompetition Boolean @default(false)
}

model AppSettings {
  id        String   @id @default(cuid())
  feature   String   @unique
  minRole   String   @default("관리자")
  enabled   Boolean  @default(false)
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IncomeCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NtpRecord {
  id          String   @id @default(cuid())
  bookingId   String
  memberId    String
  memberName  String
  holeNumber  Int
  distance    Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([bookingId, memberId, holeNumber])
  @@index([bookingId])
}

model BingoSettings {
  id              String   @id @default(cuid())
  gridSize        Int      @default(5)
  bingoTargetLines Int     @default(5)
  bingoGrid       Json     @default("[]")
  usedMembers     Json     @default("[]")
  selectedCells   Json     @default("[]")
  isEditMode      Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberName String
  path       String
  action     String
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([memberId])
  @@index([createdAt])
}

model WinnerPrediction {
  id                String   @id @default(cuid())
  roundingId        String
  booking           Booking  @relation(fields: [roundingId], references: [id], onDelete: Cascade)
  voterId           String
  voter             Member   @relation("VoterPredictions", fields: [voterId], references: [id], onDelete: Cascade)
  predictedWinnerId String
  predictedWinner   Member   @relation("PredictedWinner", fields: [predictedWinnerId], references: [id], onDelete: Cascade)
  grade             String
  createdAt         DateTime @default(now())

  @@unique([roundingId, voterId, grade])
  @@index([roundingId])
  @@index([voterId])
}
